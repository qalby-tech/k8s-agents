#!/usr/bin/env bash
#
# fleet — thin wrapper over OpenSSH ControlMaster for the AI daemon's target fleet.
#
# Design (SSH-only, no MCP, no exposed ports):
#   * Shell AND GUI both ride a single SSH :22 connection per target.
#   * The cua Computer Server stays bound to 127.0.0.1:8000 INSIDE each GUI guest
#     and is reached with `ssh <target> 'curl 127.0.0.1:8000/cmd'` — the curl runs
#     in-guest against loopback; the JSON (incl. base64 screenshot) returns over SSH.
#     The server is never exposed on the network; the SSH key is the only gate.
#   * ControlMaster keeps one persistent master socket per target, so every call
#     after the first reuses it (no re-handshake) and auto-reconnects (ControlPersist).
#
# Connection details (HostName/User/IdentityFile/UserKnownHostsFile) live in
# ~/.ssh/config Host blocks, rendered by the operator (see ssh_config.tmpl). This
# file only needs each target's name + kind (terminal|gui) + os (linux|windows),
# from $FLEET_TARGETS.
#
# Usage:
#   fleet list
#   fleet up   <name>                 # pre-open the multiplexed master
#   fleet status <name>               # check master socket
#   fleet down <name>                 # close the master
#   fleet run  <name> <cmd...>        # run a shell command on the target
#   fleet shell <name>                # interactive shell (human/debug)
#   fleet push <name> <local> <remote>
#   fleet pull <name> <remote> <local>
#   fleet gui  <name> <verb> [args]   # GUI action via in-guest cua /cmd (see VERBS)
#   fleet gui-raw <name> '<json>'     # send a raw cua /cmd body
#   fleet screenshot <name> <out.png> # capture + decode to a file
#
# Env: FLEET_TARGETS (default /etc/fleet/targets.json), CUA_PORT (8000),
#      CUA_TOKEN (optional; sent as an auth header if set).
set -euo pipefail

FLEET_TARGETS="${FLEET_TARGETS:-/etc/fleet/targets.json}"
CUA_PORT="${CUA_PORT:-8000}"
CUA_TOKEN="${CUA_TOKEN:-}"

die(){ echo "fleet: $*" >&2; exit 1; }
need(){ command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1"; }
need ssh; need jq

[ -f "$FLEET_TARGETS" ] || die "no target manifest at $FLEET_TARGETS (set FLEET_TARGETS)"
mkdir -p "$HOME/.ssh/cm"   # ControlPath dir (matches ssh_config.tmpl)

tfield(){ jq -r --arg n "$1" --arg f "$2" '.[]|select(.name==$n)|.[$f]//empty' "$FLEET_TARGETS"; }
texists(){ [ -n "$(tfield "$1" name)" ]; }
require_target(){ texists "$1" || die "unknown target: $1 (see: fleet list)"; }
require_gui(){ [ "$(tfield "$1" kind)" = "gui" ] || die "$1 is not a gui target"; }

# ── cua /cmd schema ──────────────────────────────────────────────────────────
# VERIFIED against cua-computer-server 0.3.39 source (computer_server/main.py,
# handlers/{base,linux,windows}.py):
#   * envelope:   {"command": <name>, "params": {...}}
#   * verbs below use canonical names; click/type/key are also native aliases
#   * params:     left_click(x,y) move_cursor(x,y) scroll(x,y) type_text(text)
#                 press_key(key) hotkey(keys:[...])
#   * /cmd reply: Server-Sent Events — one `data: {json}\n\n` line, text/plain.
#                 cua_send() strips the `data: ` prefix → clean JSON downstream.
#   * screenshot: {"success":true,"image_data":<base64>,"format":"png"}
#   * auth:       NONE unless the server runs with CONTAINER_NAME set (cloud mode);
#                 our self-hosted loopback server needs no token.
CUA_IMG_FIELD="${CUA_IMG_FIELD:-.image_data}"   # jq path to base64 screenshot in the reply
cua_payload(){ # verb [args...] -> JSON body on stdout
  local verb="$1"; shift
  case "$verb" in
    screenshot) jq -nc '{command:"screenshot"}' ;;
    click)      jq -nc --argjson x "$1" --argjson y "$2" '{command:"left_click",  params:{x:$x,y:$y}}' ;;
    rclick)     jq -nc --argjson x "$1" --argjson y "$2" '{command:"right_click", params:{x:$x,y:$y}}' ;;
    dclick)     jq -nc --argjson x "$1" --argjson y "$2" '{command:"double_click",params:{x:$x,y:$y}}' ;;
    move)       jq -nc --argjson x "$1" --argjson y "$2" '{command:"move_cursor", params:{x:$x,y:$y}}' ;;
    scroll)     jq -nc --argjson x "$1" --argjson y "$2" '{command:"scroll",      params:{x:$x,y:$y}}' ;;
    type)       jq -nc --arg t "$1" '{command:"type_text", params:{text:$t}}' ;;
    key)        jq -nc --arg k "$1" '{command:"press_key", params:{key:$k}}' ;;
    hotkey)     jq -nc '$ARGS.positional | {command:"hotkey", params:{keys:.}}' --args "$@" ;;
    *) die "unknown gui verb: $verb (screenshot|click|rclick|dclick|move|scroll|type|key|hotkey)" ;;
  esac
}
# ─────────────────────────────────────────────────────────────────────────────

cua_send(){ # name jsonbody -> clean JSON reply on stdout (SSE prefix stripped)
  local name="$1" body="$2"
  require_gui "$name"
  # curl.exe on Windows guests dodges the PowerShell curl->Invoke-WebRequest alias.
  local curlbin="curl"; [ "$(tfield "$name" os)" = "windows" ] && curlbin="curl.exe"
  # X-API-Key only matters when the server runs in cloud mode (CONTAINER_NAME set).
  local auth=""; [ -n "$CUA_TOKEN" ] && auth="-H \"X-API-Key: $CUA_TOKEN\""
  printf '%s' "$body" | ssh "$name" -- \
    "$curlbin -s --max-time 120 -H 'Content-Type: application/json' $auth --data-binary @- http://127.0.0.1:${CUA_PORT}/cmd" \
    | sed -n 's/^data: //p' | tail -n1
}

cmd="${1:-}"; shift || true
case "$cmd" in
  list)
    jq -r '.[]|"\(.name)\t\(.kind)\t\(.os // "linux")"' "$FLEET_TARGETS" | column -t ;;
  up)      require_target "$1"; ssh -fN "$1" && echo "fleet: master up for $1" ;;
  status)  require_target "$1"; ssh -O check "$1" ;;
  down)    require_target "$1"; ssh -O exit "$1" && echo "fleet: master closed for $1" ;;
  run)     require_target "$1"; n="$1"; shift; ssh "$n" -- "$@" ;;
  shell)   require_target "$1"; exec ssh "$1" ;;
  push)    require_target "$1"; scp "$2" "$1:$3" ;;
  pull)    require_target "$1"; scp "$1:$2" "$3" ;;
  gui)     require_target "$1"; n="$1"; shift; cua_send "$n" "$(cua_payload "$@")" ;;
  gui-raw) require_target "$1"; cua_send "$1" "$2" ;;
  screenshot)
    require_target "$1"; n="$1"; out="${2:-screenshot.png}"
    cua_send "$n" "$(cua_payload screenshot)" | jq -r "$CUA_IMG_FIELD" | base64 -d > "$out"
    echo "fleet: wrote $out" ;;
  ""|-h|--help|help)
    sed -n '2,40p' "$0" | sed 's/^# \{0,1\}//' ;;
  *) die "unknown command: $cmd (try: fleet help)" ;;
esac
